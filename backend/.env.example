# SmokeStack ERP backend — environment (placeholders only; never commit secrets)
# PostgreSQL connection. On Render, use the database's Internal Connection String.
DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/smokestack
# Leave DATABASE_URL empty to use a local SQLite file for dev/tests.

# JWT signing secret — generate a long random value in production.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRE_MINUTES=720

# CORS: comma-separated origins allowed to call the API (your frontend URL).
CORS_ORIGINS=https://smokestack-erp.onrender.com,http://localhost:8000

# Seed demo data on first boot (owner/admin/... accounts + sample records).
SEED_ON_START=true
# Password for the seeded demo accounts. Keep it short (bcrypt caps at 72 bytes).
# Set a real value in the host's secret store; never commit a production secret.
SEED_PASSWORD=demo1234
